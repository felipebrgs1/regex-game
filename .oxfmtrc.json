{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "semi": false,
  "singleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "htmlWhitespaceSensitivity": "css",
  "ignorePatterns": ["dist/**", "node_modules/**", ".nuxt/**", ".output/**"]
}
